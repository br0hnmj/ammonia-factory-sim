function PrintResults (Temp_oC,Press_Atm,CoolingoC,PurgeRate,FlowRate,NH3NetYield,TimeEquilibrate,FinalTotalOutput,VariableCosts,TotalCostperTon,NetEarningsPerDay,FactoryStatus,CAT)
	{
		var CATname='';
		if(CAT==1){CATname='Regular';}
		else if(CAT==1.5){CATname='best';}
		else if(CAT==1.2){CATname='Improved';}
		else{CATname='Regular';}
		///////////////////////////////////////////////////////////////
		var idxLastRow = document.getElementById('table3Body').rows.length;
		var table=document.getElementById("table3Body");
		var row=table.insertRow(idxLastRow);
		var cell0=row.insertCell(0);
		var cell1=row.insertCell(1);
		var cell2=row.insertCell(2);
		var cell3=row.insertCell(3);
		var cell4=row.insertCell(4);
		var cell5=row.insertCell(5);
		var cell6=row.insertCell(6);
		var cell7=row.insertCell(7);
		var cell8=row.insertCell(8);
		var cell9=row.insertCell(9);
		var cell10=row.insertCell(10);
		var cell11=row.insertCell(11);
		var cell12=row.insertCell(12);/*
		var cell13=row.insertCell(13);*/
		cell0.innerHTML=""+(idxLastRow+1)+"";
		cell1.innerHTML=''+Press_Atm+'';
		cell2.innerHTML=''+Temp_oC+'';
		cell3.innerHTML=''+CATname+'';
		cell4.innerHTML=''+FlowRate+'';
		cell5.innerHTML=''+PurgeRate+'%';
		cell6.innerHTML=''+CoolingoC+'';
		cell7.innerHTML=''+NH3NetYield+'';
		cell8.innerHTML=''+TimeEquilibrate+'';
		cell9.innerHTML=''+TotalCostperTon+'';
		cell10.innerHTML=''+FinalTotalOutput+'';
		var MoneyFormat=formatMoney(NetEarningsPerDay);
		cell11.innerHTML=''+MoneyFormat+'';
		cell12.innerHTML=''+FactoryStatus+'';/*
		cell13.innerHTML='';*/
	}
