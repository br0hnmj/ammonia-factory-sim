/**************************************/
function CreateAmonia(ElemT)
	{
		var CurValue_N3=parseInt(document.getElementById("N3_OvenCount").value);
		var CurValue_H2=parseInt(document.getElementById("H2_OvenCount").value);
		var CurValue_NH3=parseInt(document.getElementById("NH3_Count").value);
		var AmoniaInit=document.getElementById("AmoniaInit").value;
		CurValue_NH3=CurValue_NH3+1;
		if(CurValue_H2>=3 && CurValue_N3>=1)
			{
				$('.NH3').animate({'opacity':1}, 50);
				ammonia.push(new Production(450,133,10, '','NH3',CurValue_NH3));
				/**************************************/
				var newCurValue=1000+CurValue_NH3;
				/**			Fresh H2				 **/
				/*********************Set_H************/
				$('#H2_'+newCurValue+'').animate({'opacity':0.7}, 50);
				hydrogens.push(new Reaction(211,100,10, '#FF3','H2',newCurValue)); 
				/**************************************/
				/**				N3					 **/
				/**************************************/
				$('#N3_'+newCurValue+'').animate({'opacity':0.7}, 50);
				nitrogens.push(new Reaction(211,40,10, '#6688ff','N3',newCurValue)); 
				/**************************************/
				/**************************************/
				if(AmoniaInit==0)
					{NH3Track();}
		}			
	}
