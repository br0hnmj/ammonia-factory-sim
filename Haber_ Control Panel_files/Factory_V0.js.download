function Reset_Factory_Control()
	{ 
		var CurValue=parseInt(document.getElementById("Press_Atm").value);
		var PrevFan=parseInt((parseInt(CurValue))/100);
		$("div#fan"+PrevFan+"").attr('id','fan2');
		//canvasDemo.init();
		document.getElementById("SmokeChimney").innerHTML='';
		document.getElementById("Temp_oC").value=document.getElementById("ShowTemp_oC").value=parseInt(200);
		document.getElementById("Temp_K").value=document.getElementById("ShowTemp_K").value=parseInt(473);
		document.getElementById("Press_Atm").value=document.getElementById("ShowPress_Atm").value=parseInt(300);
		document.getElementById("OperationT").value=document.getElementById("ShowOperationT").value=parseInt(24);
		document.getElementById("FlowRate").value=document.getElementById("ShowFlowRate").value=parseInt(13800);
		document.getElementById("PurgeRate").value=document.getElementById("ShowPurgeRate").value=parseInt(10);
		document.getElementById("CoolingoC").value=document.getElementById("ShowCoolingoC").value=parseInt(-100);
		SetCatalyst('Regular');
	}
