// The Production class
Production = (function() {
// constructor
function Production(x,y,radius,color,ElemT,Elem){
    this.center = {x:x, y:y};  
    this.radius = radius;               
    this.color = color;
	var Type= this.Type = ElemT;           
    this.EleNum = Elem;
    this.dx = 1;               
    this.dy = 1;        
    this.boundaryHeight = $('#NH_Particles_Box').height();
    this.boundaryWidth = $('#NH_Particles_Box').width();
	this.dom  = $('<div class="NH3" id="NH3_'+Elem+'"><div id="An1"></div> <div id="Ah1"></div> <div id="Ah2"></div> <div id="Ah3"></div></div>').appendTo('#NH_Particles_Box');
    // the rectange div a Particles
    this.dom.width(radius*0.7);
    this.dom.height(radius*0.7);
   // this.dom.css({'border-radius':radius,background:color});
    this.Produce(x,y);         
  }
  // Place the Particle at center x, y
  Production.prototype.Produce = function(x,y)
		{
			this.center.x = Math.round(x);
			this.center.y = Math.round(y);
		};
  // move and bounce the Particles
  var CurValue_NH3;
  Production.prototype.moveNH = function()
  {
	var diameter = this.radius * 2;                                               
	var radius = this.radius;  
	/////////////////////////////////////////////
	var A_Level=parseInt(document.getElementById('Amonia_Level').style.width);
	var TotalOutput=parseInt(document.getElementById('HiddenTotalOutput').value);
	var CurAmonia=parseInt(document.getElementById("NH3_Count").value);
	/////////////////////////////////////////////	 
	if(this.EleNum==3 || this.EleNum==6)
		{
			if (this.center.y==133 && this.center.x<570)
				{
					this.dom.css({left: this.center.x + this.dx}); 
					this.Produce(this.center.x+ this.dx,this.center.y);  
				}
			else if (this.center.x==570 && this.center.y>30) 
				{
					this.dom.css({"margin-top": this.center.y - this.dy});
					this.Produce(this.center.x,this.center.y- this.dy);  
				} 
			else if (this.center.y==30 && this.center.x>485)
				 {
					this.dom.css({left: this.center.x - this.dx}); 
					this.Produce(this.center.x- this.dx,this.center.y);  
				} 
			else if (this.center.x==485 && this.center.y>10) 
				{
					this.dom.css({"margin-top": this.center.y - this.dy});
					this.Produce(this.center.x,this.center.y- this.dy);  
				} 
			else if (this.center.y==10 && this.center.x>450)
				 {
					this.dom.css({left: this.center.x - this.dx}); 
					this.Produce(this.center.x- this.dx,this.center.y);  
				}
			else if (this.center.x==450 && this.center.y<133) 
				{
					this.dom.css({"margin-top": this.center.y + this.dy});
					this.Produce(this.center.x,this.center.y+ this.dy);
				}
		}
	else
		{
			if (this.center.y==133 && this.center.x<570)
				 {
					this.dom.css({left: this.center.x + this.dx}); 
					this.Produce(this.center.x+ this.dx,this.center.y);  
				}
			else if (this.center.x==570 && this.center.y<159) 
				{
					this.dom.css({"margin-top": this.center.y + this.dy});
					this.Produce(this.center.x,this.center.y+ this.dy);  
				}
			else if (this.center.y==159 && this.center.x<643)
				 {
					this.dom.css({left: this.center.x + this.dx}); 
					this.Produce(this.center.x+ this.dx,this.center.y);  
				} 
			else if (this.center.y==159 && this.center.x==643)
				 {
					 document.getElementById("NH3_Count").value=parseInt(document.getElementById("NH3_Count").value)+1;
					this.dom.css({"opacity": "0"});
				 } 
		}
   };
  ///////////////////////
  return Production;
})();
