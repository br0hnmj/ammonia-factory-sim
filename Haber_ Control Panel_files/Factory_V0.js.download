/*==========================*/
function RunDecInc(Direction,field)
{
	
	var CurValue='';
	var Setter='';
	var Set=1;
	var SetFrom=0;
	var SetTo=0;
	if(field=='Temp_oC' || field=='Press_Atm'|| field=='OperationT' || field=='FlowRate'    || field=='PurgeRate'  || field=='CoolingoC' )// 
		{
			if(field=='OperationT')
				{
				CurValue=parseInt(document.getElementById(""+field+"").value);
				SetFrom=1;
				SetTo=24;
				Setter='Run';
				}
			else if(field=='Temp_oC')
				{
				CurValue=parseInt(document.getElementById(""+field+"").value);	
				Temp_K=CurValue+273;
				Set=25;
				SetFrom=200;
				SetTo=600;
				Setter='Run';
				}
			else if(field=='Press_Atm')
				{
				CurValue=parseInt(document.getElementById(""+field+"").value);
				Set=50;
				SetFrom=100;
				SetTo=1000;
				Setter='Run';
				var PrevFan=parseInt((parseInt(CurValue))/100);
				if(Direction=='More')
					{var SetFan=parseInt((parseInt(CurValue)+Set)/100);}
				///////////////////////////////////
				else if(Direction=='Less')
					{var SetFan=parseInt((parseInt(CurValue)-Set)/100);}
				$("div#fan"+PrevFan+"").attr('id','fan'+SetFan+'');
				}
			else if( field=='FlowRate')
				{
				CurValue=parseInt(document.getElementById(""+field+"").value);
				Set=50;
				SetFrom=10800;
				SetTo=16800;
				Setter='Run';
				}
			else if(field=='PurgeRate')
				{
				CurValue=parseInt(document.getElementById(""+field+"").value);
				Set=5;
				SetFrom=0;
				SetTo=25;
				Setter='Run';
				}
			else if(field=='CoolingoC')
				{
				CurValue=parseInt(document.getElementById(""+field+"").value);
				Set=10;
				SetFrom=-150;
				SetTo=100;
				Setter='Run';
				}
			else
				{Setter='';}
		}
	if(Setter=='Run')
		{
		if(Direction=='More' && CurValue<SetTo)
			{
				ValueHolder=document.getElementById(""+field+"").value=document.getElementById("Show"+field+"").value=parseInt(CurValue)+Set;
			}
		///////////////////////////////////
		else if(Direction=='Less' && CurValue>SetFrom)
			{ 
				ValueHolder=document.getElementById(""+field+"").value=document.getElementById("Show"+field+"").value=parseInt(CurValue)-Set;
			}
		///////////////////////////////////			
		if(field=='Temp_oC')
				{
					
				if(500<=ValueHolder && ValueHolder<=600)
					{ document.getElementById("OvenFire").innerHTML='<img src="/wp-content/interactive/haberplant/H_images/Fire/NewFire5.gif" />';}
				else if(400<=ValueHolder && ValueHolder<500)
					{ document.getElementById("OvenFire").innerHTML='<img src="/wp-content/interactive/haberplant/H_images/Fire/NewFire4.gif" />';}
				else if(300<=ValueHolder && ValueHolder<400)
					{ document.getElementById("OvenFire").innerHTML='<img src="/wp-content/interactive/haberplant/H_images/Fire/NewFire3.gif" />';}
				else if(200<ValueHolder && ValueHolder<300)
					{ document.getElementById("OvenFire").innerHTML='<img src="/wp-content/interactive/haberplant/H_images/Fire/NewFire2.gif" />';}
				else
					{document.getElementById("OvenFire").innerHTML='<img src="/wp-content/interactive/haberplant/H_images/Fire/NewFire1.gif" />';}
				//if(Direction=='More'){canvasDemo.fanUp();}else{canvasDemo.fanDown();}
				Temp_K = document.getElementById("Temp_K").value=document.getElementById("ShowTemp_K").value=ValueHolder+273;				
				}
		///////////////////////////////////		
		}
}
/*==========================*/
function SetCatalyst(TypeC)
{
	
	var CatSelect=document.getElementById(TypeC);
	
		var CaV = document.getElementById('CatalystVal');
		if(TypeC=='None')
			{CaV.value=1;CatSelect.checked=true}
		else if(TypeC=='Regular')
			{CaV.value=1;CatSelect.checked=true}
		else if(TypeC=='Improved')
			{CaV.value=1.2;CatSelect.checked=true}
		else if(TypeC=='Highest')
			{CaV.value=1.5;CatSelect.checked=true}
		else
			{CaV.value=1;CatSelect.checked=true}
}
